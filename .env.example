# PostgreSQL
POSTGRES_USER=chat
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=chat

# JWT secrets (must be strong random strings, at least 32 bytes)
JWT_SECRET=change_this_to_a_random_string_min_64_chars
JWT_REFRESH_SECRET=change_this_to_another_random_string_min_64_chars

# Bcrypt
BCRYPT_ROUNDS=12

# CORS (use your domain in production)
CORS_ORIGIN=*

# File upload max size in bytes (default 20MB)
FILE_UPLOAD_MAX_BYTES=20971520

# Public HTTP port
HTTP_PORT=80
